<%- include('partials/header', { title: 'Configurações' }) %>

<h1>Configurações</h1>

<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>

<div class="box">
    <h2>Distribuição do APK</h2>

    <p style="color:#555;margin-bottom:16px">
        Hospedagem do APK para instalação remota em TVs Android fora da rede local.
        Para Fire TV Stick e IZY Play próximos, prefira instalação via ADB na LAN.
    </p>

    <% if (apkInfo) { %>
        <p style="margin-bottom:8px">
            <strong>APK disponível:</strong>
            <%= (apkInfo.size / 1024 / 1024).toFixed(1) %> MB —
            enviado em <%= new Date(apkInfo.mtime).toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' }) %>
        </p>
    <% } else { %>
        <p style="color:#c0392b;margin-bottom:8px">
            ⚠️ Nenhum APK enviado ainda. Faça upload abaixo para habilitar o download remoto.
        </p>
    <% } %>

    <% if (apkToken) { %>
        <label style="display:block;font-size:13px;color:#555;margin-top:12px;margin-bottom:4px">
            Link para instalar o APK (digite no Downloader ou file manager da TV):
        </label>
        <div style="display:flex;gap:8px;margin-bottom:12px">
            <input id="apk-url" type="text" readonly
                   value="<%= baseUrl %>/apk/<%= apkToken %>"
                   style="flex:1;padding:8px 12px;border:1px solid #ddd;border-radius:4px;font-size:13px;font-family:monospace;background:#f7f7f7">
            <button type="button" class="btn btn-primary" onclick="copyApkUrl()">Copiar</button>
        </div>
        <p style="font-size:12px;color:#888;margin-bottom:16px">
            Token atual: <code><%= apkToken %></code>.
            Se o link vazar, clique em "Rotacionar" abaixo para invalidá-lo.
        </p>
    <% } %>

    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:20px">
        <form action="/apk/upload" method="POST" enctype="multipart/form-data" style="display:flex;gap:8px;align-items:center">
            <input type="file" name="apk" accept=".apk" required
                   style="font-size:13px">
            <button type="submit" class="btn btn-primary">Enviar novo APK</button>
        </form>
        <form action="/apk/rotate-token" method="POST"
              onsubmit="return confirm('Rotacionar o token invalida todos os links de download anteriores. Continuar?')">
            <button type="submit" class="btn btn-danger">Rotacionar token</button>
        </form>
    </div>

    <details style="font-size:13px;color:#555">
        <summary style="cursor:pointer;color:#2980b9">Como instalar na TV remota</summary>
        <ol style="margin-top:8px;padding-left:20px;line-height:1.6">
            <li>Na TV, habilite "Fontes desconhecidas" / "Apps de origens desconhecidas" nas configurações.</li>
            <li>Instale o app <strong>Downloader</strong> (by AFTVnews) pela Play Store / Amazon App Store.</li>
            <li>Abra o Downloader, digite o link acima no campo de URL e clique em "Go".</li>
            <li>Quando o download terminar, aceite o prompt de instalação.</li>
            <li>O app PAI TV aparecerá como um aplicativo instalado — o cadastro do dispositivo acontece na primeira abertura.</li>
        </ol>
    </details>
</div>

<div class="box">
    <h2>Alertas por e-mail</h2>

    <% if (!gmailConfigured) { %>
        <div class="alert alert-error">
            ⚠️ Gmail não configurado no servidor. Adicione <code>GMAIL_USER</code> e <code>GMAIL_APP_PASSWORD</code> no arquivo <code>.env</code> do servidor e reinicie.
        </div>
    <% } else { %>
        <p style="color:#27ae60;margin-bottom:16px">✅ Enviando alertas por: <strong><%= gmailUser %></strong></p>
    <% } %>

    <p style="color:#555;margin-bottom:16px">
        Um e-mail é enviado quando um dispositivo fica offline por mais de 15 minutos,
        e outro quando ele volta online.
    </p>

    <form action="/settings/emails" method="POST" style="margin-bottom:24px">
        <div style="display:flex;gap:8px;margin-bottom:12px">
            <input type="email" name="email" placeholder="destinatario@email.com" required
                   style="flex:1;padding:8px 12px;border:1px solid #ddd;border-radius:4px;font-size:14px">
            <button type="submit" class="btn btn-primary">Adicionar</button>
        </div>
        <div style="display:flex;gap:16px;align-items:center;flex-wrap:wrap">
            <span style="font-size:13px;color:#555">Receber alertas de:</span>
            <label style="font-size:13px;cursor:pointer">
                <input type="radio" name="scope" value="all" checked onchange="toggleDevices(this,'new')"> Todos os dispositivos
            </label>
            <label style="font-size:13px;cursor:pointer">
                <input type="radio" name="scope" value="none" onchange="toggleDevices(this,'new')"> Nenhum
            </label>
            <label style="font-size:13px;cursor:pointer">
                <input type="radio" name="scope" value="specific" onchange="toggleDevices(this,'new')"> Dispositivos específicos
            </label>
        </div>
        <div id="devices-new" style="display:none;margin-top:10px;padding:10px;background:#f7f7f7;border-radius:4px;flex-wrap:wrap;gap:10px">
            <% if (devices.length === 0) { %>
                <span style="color:#888;font-size:13px">Nenhum dispositivo cadastrado ainda.</span>
            <% } else { %>
                <% devices.forEach(d => { %>
                    <label style="font-size:13px;cursor:pointer;white-space:nowrap">
                        <input type="checkbox" name="device_ids" value="<%= d.id %>"> <%= d.name %>
                    </label>
                <% }) %>
            <% } %>
        </div>
    </form>

    <% if (emails.length === 0) { %>
        <p style="color:#888">Nenhum destinatário cadastrado.</p>
    <% } else { %>
    <table>
        <thead>
            <tr>
                <th>E-mail</th>
                <th>Dispositivos</th>
                <th>Cadastrado em</th>
                <th>Ação</th>
            </tr>
        </thead>
        <tbody>
        <% emails.forEach(e => { %>
            <% const devIds = emailDeviceMap[e.id] || []; %>
            <% const devNames = devices.filter(d => devIds.includes(d.id)).map(d => d.name); %>
            <tr>
                <td><%= e.email %></td>
                <td>
                    <% if (e.scope === 'all') { %>
                        <span style="color:#27ae60;font-size:13px">Todos</span>
                    <% } else if (e.scope === 'none') { %>
                        <span style="color:#999;font-size:13px">Nenhum</span>
                    <% } else { %>
                        <span style="font-size:13px"><%= devNames.length ? devNames.join(', ') : '(nenhum selecionado)' %></span>
                    <% } %>
                    <br>
                    <details style="margin-top:4px">
                        <summary style="font-size:12px;color:#2980b9;cursor:pointer">Editar</summary>
                        <form action="/settings/emails/<%= e.id %>/devices" method="POST"
                              style="margin-top:8px;padding:10px;background:#f7f7f7;border-radius:4px">
                            <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:8px">
                                <label style="font-size:13px;cursor:pointer">
                                    <input type="radio" name="scope" value="all"
                                           <%= e.scope === 'all' ? 'checked' : '' %>
                                           onchange="toggleDevices(this,'<%= e.id %>')"> Todos
                                </label>
                                <label style="font-size:13px;cursor:pointer">
                                    <input type="radio" name="scope" value="none"
                                           <%= e.scope === 'none' ? 'checked' : '' %>
                                           onchange="toggleDevices(this,'<%= e.id %>')"> Nenhum
                                </label>
                                <label style="font-size:13px;cursor:pointer">
                                    <input type="radio" name="scope" value="specific"
                                           <%= e.scope === 'specific' ? 'checked' : '' %>
                                           onchange="toggleDevices(this,'<%= e.id %>')"> Específicos
                                </label>
                            </div>
                            <div id="devices-<%= e.id %>"
                                 style="flex-wrap:wrap;gap:10px;margin-bottom:8px;<%= e.scope === 'specific' ? 'display:flex' : 'display:none' %>">
                                <% if (devices.length === 0) { %>
                                    <span style="color:#888;font-size:13px">Nenhum dispositivo cadastrado ainda.</span>
                                <% } else { %>
                                    <% devices.forEach(d => { %>
                                        <label style="font-size:13px;cursor:pointer;white-space:nowrap">
                                            <input type="checkbox" name="device_ids" value="<%= d.id %>"
                                                   <%= devIds.includes(d.id) ? 'checked' : '' %>> <%= d.name %>
                                        </label>
                                    <% }) %>
                                <% } %>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm">Salvar</button>
                        </form>
                    </details>
                </td>
                <td style="font-size:12px;color:#555">
                    <%= new Date(e.created_at.replace(' ', 'T') + 'Z').toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' }) %>
                </td>
                <td>
                    <form action="/settings/emails/<%= e.id %>/delete" method="POST"
                          onsubmit="return confirm('Remover este e-mail?')">
                        <button type="submit" class="btn btn-danger btn-sm">Remover</button>
                    </form>
                </td>
            </tr>
        <% }) %>
        </tbody>
    </table>
    <% } %>
</div>

<script>
function toggleDevices(radio, id) {
    var el = document.getElementById('devices-' + id);
    if (!el) return;
    el.style.display = radio.value === 'specific' ? 'flex' : 'none';
}

function copyApkUrl() {
    var input = document.getElementById('apk-url');
    if (!input) return;
    input.select();
    input.setSelectionRange(0, 99999);
    try {
        navigator.clipboard.writeText(input.value);
    } catch {
        document.execCommand('copy');
    }
}
</script>

<%- include('partials/footer') %>
