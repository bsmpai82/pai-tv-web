<%- include('partials/header', { title: 'Logs' }) %>

<h1>Logs do sistema</h1>

<div style="display:flex;gap:12px;align-items:center;margin-bottom:20px;flex-wrap:wrap">
    <form method="GET" action="/logs" style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
        <select name="tipo" onchange="this.form.submit()"
                style="padding:6px 10px;border:1px solid #ddd;border-radius:4px;font-size:13px">
            <option value="" <%= tipo==='' ? 'selected':'' %>>Todos os tipos</option>
            <option value="dispositivo" <%= tipo==='dispositivo' ? 'selected':'' %>>Dispositivo</option>
            <option value="email"       <%= tipo==='email'       ? 'selected':'' %>>E-mail</option>
            <option value="video"       <%= tipo==='video'       ? 'selected':'' %>>Vídeo</option>
        </select>
        <select name="nivel" onchange="this.form.submit()"
                style="padding:6px 10px;border:1px solid #ddd;border-radius:4px;font-size:13px">
            <option value="" <%= nivel==='' ? 'selected':'' %>>Todos os níveis</option>
            <option value="info"   <%= nivel==='info'   ? 'selected':'' %>>Info</option>
            <option value="alerta" <%= nivel==='alerta' ? 'selected':'' %>>Alerta</option>
            <option value="erro"   <%= nivel==='erro'   ? 'selected':'' %>>Erro</option>
        </select>
    </form>

    <form action="/logs/limpar" method="POST" style="margin-left:auto"
          onsubmit="return confirm('Limpar todos os logs?')">
        <button type="submit" class="btn btn-danger btn-sm">Limpar logs</button>
    </form>
</div>

<div class="box" style="padding:0;overflow-x:auto">
    <% if (logs.length === 0) { %>
        <p style="padding:20px;color:#888">Nenhum log encontrado.</p>
    <% } else { %>
    <table style="margin:0">
        <thead>
            <tr>
                <th style="width:150px">Data/hora</th>
                <th style="width:90px">Tipo</th>
                <th style="width:70px">Nível</th>
                <th>Mensagem</th>
                <th style="width:120px">Dispositivo</th>
            </tr>
        </thead>
        <tbody>
        <% logs.forEach(l => { %>
            <%
                const nivelColor = l.nivel === 'alerta' ? '#e67e22'
                                 : l.nivel === 'erro'   ? '#c0392b'
                                 : '#27ae60';
                const tipoColor  = l.tipo === 'dispositivo' ? '#2980b9'
                                 : l.tipo === 'email'        ? '#8e44ad'
                                 : l.tipo === 'video'        ? '#16a085'
                                 : '#555';
            %>
            <tr>
                <td style="font-size:11px;color:#555;white-space:nowrap">
                    <%= new Date(l.created_at.replace(' ','T')+'Z').toLocaleString('pt-BR',{timeZone:'America/Sao_Paulo'}) %>
                </td>
                <td>
                    <span style="font-size:11px;font-weight:600;color:<%= tipoColor %>">
                        <%= l.tipo.toUpperCase() %>
                    </span>
                </td>
                <td>
                    <span style="font-size:11px;font-weight:600;color:<%= nivelColor %>">
                        <%= l.nivel.toUpperCase() %>
                    </span>
                </td>
                <td style="font-size:13px"><%= l.mensagem %></td>
                <td style="font-size:12px;color:#555"><%= l.device_name || '—' %></td>
            </tr>
        <% }) %>
        </tbody>
    </table>
    <% } %>
</div>

<%- include('partials/footer') %>
