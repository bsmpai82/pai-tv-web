<%- include('partials/header', { title: 'Dashboard' }) %>

<h1>Dashboard</h1>

<% if (offlineDevices.length > 0) { %>
<div class="alert alert-error" style="margin-bottom:20px">
    <strong>Atenção:</strong> <%= offlineDevices.length %> dispositivo(s) offline há mais de 1 hora:
    <strong><%= offlineDevices.map(d => d.name).join(', ') %></strong>
</div>
<% } %>

<div style="display:flex;gap:24px;align-items:flex-start">

    <%# Metade esquerda: cards %>
    <div style="flex:1">
        <div class="cards">
            <div class="card">
                <div class="card-number"><%= videoCount %></div>
                <div class="card-label">Vídeos</div>
                <a href="/videos">Gerenciar</a>
            </div>
            <div class="card">
                <div class="card-number"><%= playlistCount %></div>
                <div class="card-label">Playlists</div>
                <a href="/playlists">Gerenciar</a>
            </div>
            <div class="card">
                <div class="card-number"><%= groupCount %></div>
                <div class="card-label">Grupos</div>
                <a href="/groups">Gerenciar</a>
            </div>
            <div class="card">
                <div class="card-number"><%= deviceCount %></div>
                <div class="card-label">Dispositivos</div>
                <% if (pendingCount > 0) { %>
                    <a href="/devices" class="alert-link"><%= pendingCount %> pendente(s)</a>
                <% } else { %>
                    <a href="/devices">Gerenciar</a>
                <% } %>
            </div>
        </div>
    </div>

    <%# Metade direita: lista de dispositivos com status %>
    <div style="flex:1">
        <div class="box" style="margin-top:0">
            <h2>Status dos dispositivos</h2>
            <% if (devices.length === 0) { %>
                <p style="color:#888">Nenhum dispositivo configurado ainda.</p>
            <% } else { %>
            <table>
                <tbody>
                <% devices.forEach(d => { %>
                    <tr>
                        <td style="width:20px">
                            <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:<%= d.is_online ? '#27ae60' : '#c0392b' %>"></span>
                        </td>
                        <td><%= d.name %></td>
                        <td style="color:#888;font-size:12px">
                            <%= d.is_online ? 'Online' : 'Offline' %>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
            <% } %>
        </div>
    </div>

</div>

<%- include('partials/footer') %>
